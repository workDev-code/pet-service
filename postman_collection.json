        {
          "name": "Create Booking",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const scheduledAt = new Date(Date.now() + 3 * 24 * 60 * 60 * 1000).toISOString();",
                  "pm.collectionVariables.set('scheduledAt', scheduledAt);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('bookingId', json.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"petId\": {{petId}},\n  \"serviceId\": {{serviceId}},\n  \"scheduledAt\": \"{{scheduledAt}}\",\n  \"address\": \"123 Paw Street\",\n  \"notes\": \"Please call on arrival\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/bookings",
              "host": [
                "{{baseUrl}}"
              ],
