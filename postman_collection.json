                  "  pm.expect(json).to.be.an('array');",
                  "  json.forEach((user) => {",
                  "    pm.expect(['CUSTOMER', 'STAFF']).to.include(user.role);",
                  "    pm.expect(user.deletedAt).to.be.a('string');",
                  "  });",
                  "});",
                  "const json = pm.response.json();",
                  "if (json.length > 0) {",
                  "  pm.collectionVariables.set('deletedUserId', json[0].id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
