    {
      "name": "Pets",
      "description": "Customer pet workflow. Run Login - Customer first so the bearer token belongs to a CUSTOMER account.",
      "item": [
        {
          "name": "List My Pets",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('returns my pets', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json()).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/pets",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "pets"
              ]
            }
          }
        },
        {
          "name": "Create Pet - Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('creates a pet for the current customer', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.id).to.be.a('number');",
                  "  pm.expect(json.name).to.eql('Biscuit');",
                  "});",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('petId', json.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Biscuit\",\n  \"species\": \"Dog\",\n  \"breed\": \"Corgi\",\n  \"weightKg\": 10.5,\n  \"notes\": \"Friendly, likes treats\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/pets",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "pets"
              ]
            }
          }
        },
        {
          "name": "Update Pet - Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('updates the current customer pet', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.id).to.eql(Number(pm.collectionVariables.get('petId')));",
                  "  pm.expect(json.name).to.eql('Biscuit Updated');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Biscuit Updated\",\n  \"species\": \"Dog\",\n  \"breed\": \"Corgi Mix\",\n  \"weightKg\": 11.2,\n  \"notes\": \"Updated notes for this pet\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/pets/{{petId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "pets",
                "{{petId}}"
              ]
            }
          }
        },
        {
          "name": "Upload Pet Photo - Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('uploads a pet photo', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.id).to.eql(Number(pm.collectionVariables.get('petId')));",
                  "  pm.expect(json.photoUrl).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/pets/{{petId}}/photo",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "pets",
                "{{petId}}",
                "photo"
              ]
            }
          }
        },
        {
          "name": "Delete Pet - Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('deletes a pet without bookings', function () {",
                  "  pm.response.to.have.status(204);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/pets/{{petId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "pets",
                "{{petId}}"
              ]
            }
          }
        }
